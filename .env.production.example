# Production env template for the Docker Compose deployment (012).
#
# Usage (the ONLY supported path — DR-006):
#   cp .env.production.example .env
#   # edit .env: fill POSTGRES_* / secrets / ALLOWED_ORIGIN
#   docker compose up -d --build
#
# Compose reads this copied root .env for BOTH ${VAR} interpolation (to compose
# DATABASE_URL / HTTP_PORT) and env_file injection into the containers. Keep the
# real .env out of git and out of images (.gitignore / .dockerignore already do).
#
# NOTE: DATABASE_URL and REDIS_URL are NOT set here — compose composes them from
# POSTGRES_* and the internal service network. Do not hand-write them.

# --- Postgres (single source for DATABASE_URL) ---------------------------------
POSTGRES_USER=slides
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=slides_agent

# --- Edge ----------------------------------------------------------------------
# Host port nginx publishes (container always listens on 80). TLS terminates
# upstream (LB / Cloudflare).
HTTP_PORT=80
# Browser origin allowed by production CORS — the public URL users hit.
ALLOWED_ORIGIN=https://slides.example.com

# --- Auth (feature 005) — REQUIRED by the api -----------------------------------
# AUTH_JWT_SECRET is REQUIRED: the api fails fast on startup without it. The
# worker does NOT load AuthModule, so it does not require this.
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRES_IN=30d
AUTH_JWT_ISSUER=slides-agent
# Allowlisted accounts as a JSON array; passwordHash via `pnpm auth:hash`. Read by
# the migrate job's seed AND the api at login.
# [{ "id":"user_owner","username":"owner@example.com","displayName":"Owner","passwordHash":"<scrypt>","active":true }]
AUTH_ACCOUNTS=[]
# Per-IP login rate limit (brute-force protection).
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000

# --- Backend LLM (feature 003+) — never exposed to the web bundle ---------------
# If OPENAI_API_KEY is empty, generation still works via deterministic fallbacks.
LLM_PROVIDER=openai
LLM_MODEL=
OPENAI_API_KEY=
# Optional per-stage model overrides (leave empty to use LLM_MODEL).
SEMANTIC_SEGMENTATION_MODEL=
DESIGN_PLANNING_MODEL=
LLM_MAX_REPAIR_ATTEMPTS=1

# --- Preview queue / rate limits (optional knobs) -------------------------------
PREVIEW_QUEUE_NAME=preview-jobs
PREVIEW_WORKER_CONCURRENCY=1
PREVIEW_TIMEOUT_SWEEP_INTERVAL_MS=30000
PREVIEW_RATE_LIMIT_MAX=5
PREVIEW_RATE_LIMIT_WINDOW_MS=60000

# --- DB connection-pool tuning (optional) ---------------------------------------
DB_POOL_MAX=5
DB_WORKER_POOL_MAX=2
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
