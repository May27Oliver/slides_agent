{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:slides-agent:contracts:slide-generation",
  "title": "Slide Generation Preview Contract",
  "type": "object",
  "required": ["request", "response"],
  "properties": {
    "request": {
      "$ref": "#/$defs/GeneratePreviewRequest"
    },
    "response": {
      "$ref": "#/$defs/GeneratePreviewResponse"
    }
  },
  "$defs": {
    "GeneratePreviewRequest": {
      "type": "object",
      "required": ["sourceContent", "deckBrief"],
      "properties": {
        "sourceContent": {
          "type": "string",
          "minLength": 1
        },
        "deckBrief": {
          "$ref": "#/$defs/DeckBrief"
        }
      },
      "additionalProperties": false
    },
    "DeckBrief": {
      "type": "object",
      "required": ["purpose", "audience"],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "styleDirection": {
          "type": "string"
        },
        "chartEmphasis": {
          "type": "string"
        },
        "segmentationGuidance": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "tone": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "GeneratePreviewResponse": {
      "type": "object",
      "required": ["slideDeck", "previewArtifact"],
      "properties": {
        "slideDeck": {
          "$ref": "#/$defs/SlideDeck"
        },
        "previewArtifact": {
          "$ref": "#/$defs/PreviewArtifact"
        }
      },
      "additionalProperties": false
    },
    "SlideDeck": {
      "type": "object",
      "required": ["id", "title", "purpose", "audience", "designSystem", "slides", "reviewReport"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "audience": {
          "type": "string"
        },
        "designSystem": {
          "$ref": "#/$defs/DesignSystem"
        },
        "slides": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Slide"
          }
        },
        "reviewReport": {
          "$ref": "#/$defs/ReviewReport"
        }
      },
      "additionalProperties": false
    },
    "DesignSystem": {
      "type": "object",
      "required": ["themeName", "palette", "typography", "spacing", "visualDensity", "layoutGrid", "slidePatterns", "chartStyle"],
      "properties": {
        "themeName": {
          "type": "string"
        },
        "palette": {
          "type": "object"
        },
        "typography": {
          "type": "object"
        },
        "spacing": {
          "type": "object"
        },
        "visualDensity": {
          "enum": ["low", "medium", "high"]
        },
        "layoutGrid": {
          "type": "string"
        },
        "slidePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "chartStyle": {
          "type": "string"
        },
        "uiUxProMaxNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "Slide": {
      "type": "object",
      "required": [
        "id",
        "type",
        "title",
        "message",
        "outline",
        "layout",
        "layoutIntent",
        "contentBlocks",
        "sourceTrace"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "enum": ["title", "section", "content", "comparison", "timeline", "table", "metrics", "quote", "action"]
        },
        "title": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "outline": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/SlideOutlineItem"
          }
        },
        "layout": {
          "type": "string"
        },
        "layoutIntent": {
          "$ref": "#/$defs/LayoutIntent"
        },
        "contentBlocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContentBlock"
          }
        },
        "sourceTrace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "speakerNotesDraft": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "SlideOutlineItem": {
      "type": "object",
      "required": ["text", "sourceTrace", "emphasis"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "sourceTrace": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "emphasis": {
          "enum": ["main_point", "evidence", "risk", "decision", "action", "context"]
        }
      },
      "additionalProperties": false
    },
    "LayoutIntent": {
      "type": "object",
      "required": ["priority", "density", "emphasis"],
      "properties": {
        "priority": {
          "enum": [
            "message_first",
            "metrics_first",
            "comparison",
            "timeline",
            "risk_matrix",
            "table_dense"
          ]
        },
        "density": {
          "enum": ["low", "medium", "high"]
        },
        "emphasis": {
          "enum": ["narrative", "numbers", "risks", "decisions", "actions"]
        }
      },
      "additionalProperties": false
    },
    "ContentBlock": {
      "type": "object",
      "required": ["kind", "content"],
      "properties": {
        "kind": {
          "enum": ["paragraph", "bullets", "metric", "table", "timeline", "callout", "quote", "chart_placeholder", "fallback_text"]
        },
        "content": {
          "type": "object"
        },
        "chartIntentId": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ReviewReport": {
      "type": "object",
      "required": ["assumptions", "omittedOrCompressedContent", "uncertainClaims", "chartingDecisions", "humanReviewNotes"],
      "properties": {
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "omittedOrCompressedContent": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uncertainClaims": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "chartingDecisions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "humanReviewNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "PreviewArtifact": {
      "type": "object",
      "required": ["html", "generationSummary"],
      "properties": {
        "html": {
          "type": "string",
          "minLength": 1
        },
        "generationSummary": {
          "$ref": "#/$defs/GenerationSummary"
        }
      },
      "additionalProperties": false
    },
    "GenerationSummary": {
      "type": "object",
      "required": ["slideCount", "sourceFactCount", "chartIntentCount", "uncertainClaimCount"],
      "properties": {
        "slideCount": {
          "type": "integer",
          "minimum": 1
        },
        "sourceFactCount": {
          "type": "integer",
          "minimum": 0
        },
        "chartIntentCount": {
          "type": "integer",
          "minimum": 0
        },
        "uncertainClaimCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
