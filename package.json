{
  "name": "html-slides-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "dev:iterm": "scripts/dev.sh",
    "test": "pnpm run test:domain && pnpm run test:contracts && pnpm run test:api && pnpm run test:web",
    "test:domain": "pnpm --filter @slides-agent/domain test",
    "test:contracts": "pnpm --filter @slides-agent/contracts test",
    "test:api": "pnpm --filter @slides-agent/api test",
    "test:web": "pnpm --filter @slides-agent/web test",
    "test:e2e": "pnpm --filter @slides-agent/web test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
