{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:slides-agent:contracts:slide-generation",
  "title": "Slide Generation Preview Contract",
  "type": "object",
  "required": ["request", "response"],
  "properties": {
    "request": {
      "$ref": "#/$defs/GeneratePreviewRequest"
    },
    "response": {
      "$ref": "#/$defs/GeneratePreviewResponse"
    }
  },
  "$defs": {
    "GeneratePreviewRequest": {
      "type": "object",
      "required": ["sourceContent", "deckBrief"],
      "properties": {
        "sourceContent": {
          "type": "string",
          "minLength": 1
        },
        "deckBrief": {
          "$ref": "#/$defs/DeckBrief"
        }
      },
      "additionalProperties": false
    },
    "DeckBrief": {
      "type": "object",
      "required": ["purpose", "audience"],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "styleDirection": {
          "type": "string"
        },
        "chartEmphasis": {
          "type": "string"
        },
        "segmentationGuidance": {
          "type": "string"
        },
        "language": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "GeneratePreviewResponse": {
      "type": "object",
      "required": ["slideDeck", "designPlanningResult", "previewArtifact"],
      "properties": {
        "slideDeck": {
          "$ref": "#/$defs/SlideDeck"
        },
        "designPlanningResult": {
          "$ref": "#/$defs/DesignPlanningResult"
        },
        "previewArtifact": {
          "$ref": "#/$defs/PreviewArtifact"
        }
      },
      "additionalProperties": false
    },
    "SlideDeck": {
      "type": "object",
      "required": ["id", "title", "purpose", "audience", "slides", "reviewReport"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "audience": {
          "type": "string"
        },
        "slides": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Slide"
          }
        },
        "reviewReport": {
          "$ref": "#/$defs/ReviewReport"
        }
      },
      "additionalProperties": false
    },
    "DesignSystem": {
      "type": "object",
      "required": [
        "themeName",
        "palette",
        "typography",
        "spacing",
        "visualDensity",
        "layoutGrid",
        "slidePatterns",
        "chartStyle"
      ],
      "properties": {
        "themeName": {
          "type": "string"
        },
        "palette": {
          "$ref": "#/$defs/Palette"
        },
        "typography": {
          "$ref": "#/$defs/Typography"
        },
        "spacing": {
          "$ref": "#/$defs/SpacingScale"
        },
        "visualDensity": {
          "enum": ["low", "medium", "high"]
        },
        "layoutGrid": {
          "type": "string"
        },
        "slidePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "chartStyle": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Palette": {
      "type": "object",
      "required": ["background", "surface", "text", "mutedText", "accent", "warning"],
      "properties": {
        "background": {
          "type": "string"
        },
        "surface": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "mutedText": {
          "type": "string"
        },
        "accent": {
          "type": "string"
        },
        "warning": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Typography": {
      "type": "object",
      "required": ["headingFamily", "bodyFamily", "scale"],
      "properties": {
        "headingFamily": {
          "type": "string"
        },
        "bodyFamily": {
          "type": "string"
        },
        "scale": {
          "enum": ["compact", "standard", "presentation"]
        }
      },
      "additionalProperties": false
    },
    "SpacingScale": {
      "type": "object",
      "required": ["unit", "slidePadding", "blockGap"],
      "properties": {
        "unit": {
          "type": "number"
        },
        "slidePadding": {
          "type": "number"
        },
        "blockGap": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "DesignPlanningResult": {
      "type": "object",
      "required": [
        "designSystem",
        "slidePatternAssignments",
        "chartTreatmentPlans",
        "visualHierarchyPlans",
        "accessibilityNotes",
        "designReviewNotes",
        "consistencyValidation"
      ],
      "properties": {
        "designSystem": {
          "$ref": "#/$defs/DesignSystem"
        },
        "slidePatternAssignments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SlidePatternAssignment"
          }
        },
        "chartTreatmentPlans": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ChartTreatmentPlan"
          }
        },
        "visualHierarchyPlans": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/VisualHierarchyPlan"
          }
        },
        "accessibilityNotes": {
          "$ref": "#/$defs/AccessibilityNotes"
        },
        "designReviewNotes": {
          "$ref": "#/$defs/DesignReviewNotes"
        },
        "consistencyValidation": {
          "$ref": "#/$defs/DesignConsistencyValidation"
        }
      },
      "additionalProperties": false
    },
    "SlidePatternAssignment": {
      "type": "object",
      "required": ["slideId", "primaryPattern", "density", "layoutIntent", "rationale"],
      "properties": {
        "slideId": {
          "type": "string"
        },
        "primaryPattern": {
          "type": "string"
        },
        "density": {
          "enum": ["low", "medium", "high"]
        },
        "layoutIntent": {
          "$ref": "#/$defs/LayoutIntent"
        },
        "rationale": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ChartTreatmentPlan": {
      "type": "object",
      "required": ["chartIntentId", "treatment", "labelingNotes", "preservedContext"],
      "properties": {
        "chartIntentId": {
          "type": "string"
        },
        "treatment": {
          "enum": ["chart", "metric_card", "table", "timeline", "fallback_text", "review_note"]
        },
        "labelingNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preservedContext": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallbackRationale": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "VisualHierarchyPlan": {
      "type": "object",
      "required": ["slideId", "primaryMessage", "supportingEvidence", "secondaryDetails", "deEmphasizedContent"],
      "properties": {
        "slideId": {
          "type": "string"
        },
        "primaryMessage": {
          "type": "string"
        },
        "supportingEvidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "secondaryDetails": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deEmphasizedContent": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "AccessibilityNotes": {
      "type": "object",
      "required": [
        "minContrastRatio",
        "colorContrastNotes",
        "readingOrderNotes",
        "keyboardNavigationNotes",
        "manualVerificationNotes"
      ],
      "properties": {
        "minContrastRatio": {
          "type": "number"
        },
        "colorContrastNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "readingOrderNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "keyboardNavigationNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manualVerificationNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "DesignReviewNotes": {
      "type": "object",
      "required": [
        "styleDirectionInterpretation",
        "visualDensityDecision",
        "rejectedSuggestions",
        "htmlGenerationConstraints",
        "manualVerificationNotes"
      ],
      "properties": {
        "styleDirectionInterpretation": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "visualDensityDecision": {
          "type": "string"
        },
        "rejectedSuggestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "htmlGenerationConstraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manualVerificationNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "DesignConsistencyValidation": {
      "type": "object",
      "required": ["ok", "checkedSlideIds", "issues", "fallbackUsed"],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "checkedSlideIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallbackUsed": {
          "type": "boolean"
        },
        "fallbackReason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Slide": {
      "type": "object",
      "required": [
        "id",
        "slideKind",
        "type",
        "title",
        "message",
        "outline",
        "layout",
        "layoutIntent",
        "contentBlocks",
        "sourceTrace",
        "speakerNotesDraft"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "slideKind": {
          "enum": ["opening", "content", "closing"]
        },
        "type": {
          "enum": ["title", "section", "content", "comparison", "timeline", "table", "metrics", "quote", "action"]
        },
        "title": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "outline": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/SlideOutlineItem"
          }
        },
        "layout": {
          "type": "string"
        },
        "layoutIntent": {
          "$ref": "#/$defs/LayoutIntent"
        },
        "contentBlocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContentBlock"
          }
        },
        "sourceTrace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "speakerNotesDraft": {
          "type": "string",
          "maxLength": 400
        }
      },
      "additionalProperties": false
    },
    "SlideOutlineItem": {
      "type": "object",
      "required": ["text", "sourceTrace", "emphasis"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "sourceTrace": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "emphasis": {
          "enum": ["main_point", "evidence", "risk", "decision", "action", "context"]
        }
      },
      "additionalProperties": false
    },
    "LayoutIntent": {
      "type": "object",
      "required": ["priority", "density", "emphasis"],
      "properties": {
        "priority": {
          "enum": [
            "message_first",
            "metrics_first",
            "comparison",
            "timeline",
            "risk_matrix",
            "table_dense"
          ]
        },
        "density": {
          "enum": ["low", "medium", "high"]
        },
        "emphasis": {
          "enum": ["narrative", "numbers", "risks", "decisions", "actions"]
        }
      },
      "additionalProperties": false
    },
    "ContentBlock": {
      "type": "object",
      "required": ["kind", "content"],
      "properties": {
        "kind": {
          "enum": ["paragraph", "bullets", "metric", "table", "timeline", "callout", "quote", "chart_placeholder", "fallback_text"]
        },
        "content": {
          "type": "object"
        },
        "chartIntentId": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ReviewReport": {
      "type": "object",
      "required": ["assumptions", "omittedOrCompressedContent", "uncertainClaims", "chartingDecisions", "humanReviewNotes"],
      "properties": {
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "omittedOrCompressedContent": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uncertainClaims": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "chartingDecisions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "humanReviewNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "PreviewArtifact": {
      "type": "object",
      "required": ["html", "htmlGenerationValidation", "generationSummary"],
      "properties": {
        "html": {
          "type": "string",
          "minLength": 1
        },
        "htmlGenerationValidation": {
          "$ref": "#/$defs/HtmlGenerationValidation"
        },
        "generationSummary": {
          "$ref": "#/$defs/GenerationSummary"
        }
      },
      "additionalProperties": false
    },
    "HtmlGenerationValidation": {
      "type": "object",
      "required": [
        "status",
        "selfContained",
        "slideCountAndOrderPreserved",
        "contentFidelityPreserved",
        "designCompliancePreserved",
        "speakerNotesHidden",
        "keyboardNavigationPresent",
        "externalResourceIssues",
        "contentIssues",
        "designIssues",
        "repairAttempted",
        "fallbackUsed"
      ],
      "properties": {
        "status": {
          "enum": ["pass", "repair_required", "fallback_used", "failed"]
        },
        "selfContained": {
          "type": "boolean"
        },
        "slideCountAndOrderPreserved": {
          "type": "boolean"
        },
        "contentFidelityPreserved": {
          "type": "boolean"
        },
        "designCompliancePreserved": {
          "type": "boolean"
        },
        "speakerNotesHidden": {
          "type": "boolean"
        },
        "keyboardNavigationPresent": {
          "type": "boolean"
        },
        "externalResourceIssues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contentIssues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "designIssues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repairAttempted": {
          "type": "boolean"
        },
        "fallbackUsed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "GenerationSummary": {
      "type": "object",
      "required": [
        "slideCount",
        "sourceFactCount",
        "chartIntentCount",
        "uncertainClaimCount",
        "selectedTheme",
        "renderedCharts"
      ],
      "properties": {
        "slideCount": {
          "type": "integer",
          "minimum": 1
        },
        "sourceFactCount": {
          "type": "integer",
          "minimum": 0
        },
        "chartIntentCount": {
          "type": "integer",
          "minimum": 0
        },
        "uncertainClaimCount": {
          "type": "integer",
          "minimum": 0
        },
        "selectedTheme": {
          "type": "object",
          "description": "007/009: readonly applied-theme evidence (projection of the composed style kit).",
          "required": ["kitName", "ids", "fallback", "accentHues", "fonts", "structureFeatures"],
          "properties": {
            "kitName": { "type": "string" },
            "ids": {
              "type": "object",
              "required": ["style", "palette", "font"],
              "properties": {
                "style": { "type": ["string", "null"] },
                "palette": { "type": ["string", "null"] },
                "font": { "type": ["string", "null"] }
              },
              "additionalProperties": false
            },
            "fallback": { "type": "boolean" },
            "accentHues": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "base"],
                "properties": {
                  "name": { "type": "string" },
                  "base": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "fonts": {
              "type": "object",
              "required": ["heading", "body"],
              "properties": {
                "heading": { "type": "string" },
                "body": { "type": "string" }
              },
              "additionalProperties": false
            },
            "visualDensity": { "type": "string", "enum": ["low", "medium", "high"] },
            "structureFeatures": {
              "type": "object",
              "required": ["radiusPx", "shadow"],
              "properties": {
                "radiusPx": { "type": "number" },
                "shadow": { "type": "boolean" },
                "backdropBlurPx": { "type": "number" },
                "glow": { "type": "boolean" },
                "texture": { "type": "string", "enum": ["grain", "noise", "paper"] },
                "animation": {
                  "type": "object",
                  "required": ["preset", "durationMs"],
                  "properties": {
                    "preset": { "type": "string", "enum": ["aurora", "mesh"] },
                    "durationMs": { "type": "number" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "renderedCharts": {
          "type": "array",
          "description": "009: per-chart render evidence from the single render pass ([] when no charts).",
          "items": {
            "type": "object",
            "required": ["slideId", "chartIntentId", "visualKind", "fallback", "notes"],
            "properties": {
              "slideId": { "type": "string" },
              "chartIntentId": { "type": "string" },
              "visualKind": {
                "type": "string",
                "enum": [
                  "pie_donut",
                  "line",
                  "bar",
                  "metric_card",
                  "metric_group",
                  "table",
                  "fallback_text"
                ]
              },
              "fallback": { "type": "boolean" },
              "notes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["code", "message"],
                  "properties": {
                    "code": {
                      "type": "string",
                      "enum": [
                        "series_extracted",
                        "series_insufficient",
                        "unit_mismatch",
                        "invalid_pie_total",
                        "time_sort_failed",
                        "table_truncated",
                        "fallback_used",
                        "value_parse_uncertain"
                      ]
                    },
                    "message": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
