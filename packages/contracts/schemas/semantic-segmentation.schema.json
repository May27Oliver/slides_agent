{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:slides-agent:contracts:semantic-segmentation",
  "title": "Semantic Segmentation LLM Output Contract",
  "type": "object",
  "required": ["segments", "globalWarnings"],
  "properties": {
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/SemanticSegment"
      }
    },
    "globalWarnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "SemanticSegment": {
      "type": "object",
      "required": [
        "id",
        "heading",
        "sourceQuotes",
        "summary",
        "order",
        "rationale",
        "confidence",
        "warnings"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^segment_[0-9]{3}$"
        },
        "heading": {
          "type": "string",
          "minLength": 1
        },
        "sourceQuotes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/SourceQuote"
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "enum": ["high", "medium", "low"]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "SourceQuote": {
      "type": "object",
      "required": ["text", "role"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": ["heading", "body", "bullet", "table", "quote"]
        }
      },
      "additionalProperties": false
    }
  }
}
