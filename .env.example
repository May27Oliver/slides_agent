PORT=3000

# Backend-configured LLM settings. Do not expose these in frontend code,
# public API request fields, response fields, or user-facing review reports.
LLM_PROVIDER=openai
LLM_MODEL=
OPENAI_API_KEY=

# Optional separate models. Leave empty to use LLM_MODEL.
SEMANTIC_SEGMENTATION_MODEL=
DESIGN_PLANNING_MODEL=

# Bounded repair behavior for validation-backed LLM outputs.
LLM_MAX_REPAIR_ATTEMPTS=1

# Per-IP rate limit for the preview POST endpoints (shared budget).
PREVIEW_RATE_LIMIT_MAX=5
PREVIEW_RATE_LIMIT_WINDOW_MS=60000

# Async preview-job queue (Redis + BullMQ). REDIS_URL is REQUIRED: the API and
# the worker fail fast on startup / job submission if Redis is unavailable.
# These are backend runtime configuration; never expose them as public fields.
REDIS_URL=redis://127.0.0.1:6379
PREVIEW_QUEUE_NAME=preview-jobs
PREVIEW_WORKER_CONCURRENCY=1
PREVIEW_TIMEOUT_SWEEP_INTERVAL_MS=30000

# Local fallback behavior:
# - If OPENAI_API_KEY is empty, preview generation still works through deterministic fallbacks.
# - If an operation-specific model is empty, the API uses LLM_MODEL for that operation.
