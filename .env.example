PORT=3000

# Allowed browser origin for CORS in production (NODE_ENV=production). In
# development CORS is open; this only takes effect in production.
ALLOWED_ORIGIN=http://localhost:5173
# Set to 1 when the API runs behind a reverse proxy so req.ip (and thus the login
# rate limiter) uses the real client IP from X-Forwarded-For.
TRUST_PROXY=0

# Backend-configured LLM settings. Do not expose these in frontend code,
# public API request fields, response fields, or user-facing review reports.
LLM_PROVIDER=openai
LLM_MODEL=
OPENAI_API_KEY=

# Optional separate models. Leave empty to use LLM_MODEL.
SEMANTIC_SEGMENTATION_MODEL=
DESIGN_PLANNING_MODEL=

# Bounded repair behavior for validation-backed LLM outputs.
LLM_MAX_REPAIR_ATTEMPTS=1

# Per-IP rate limit for the preview POST endpoints (shared budget).
PREVIEW_RATE_LIMIT_MAX=5
PREVIEW_RATE_LIMIT_WINDOW_MS=60000

# Async preview-job queue (Redis + BullMQ). REDIS_URL is REQUIRED: the API and
# the worker fail fast on startup / job submission if Redis is unavailable.
# These are backend runtime configuration; never expose them as public fields.
REDIS_URL=redis://127.0.0.1:6379
PREVIEW_QUEUE_NAME=preview-jobs
PREVIEW_WORKER_CONCURRENCY=1
PREVIEW_TIMEOUT_SWEEP_INTERVAL_MS=30000

# Auth (feature 005). Login is required to use the generation endpoints.
# AUTH_JWT_SECRET is REQUIRED — the API fails fast on startup without it.
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRES_IN=30d
# Token issuer claim (signed + verified). Override per deployment if desired.
AUTH_JWT_ISSUER=slides-agent
# Allowlisted accounts as a JSON array. passwordHash is produced by `pnpm auth:hash`.
# [{ "id":"user_owner","username":"owner@example.com","displayName":"Owner","passwordHash":"<scrypt>","active":true }]
AUTH_ACCOUNTS=[]
# Per-IP rate limit for POST /api/auth/login (brute-force protection).
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000

# Local fallback behavior:
# - If OPENAI_API_KEY is empty, preview generation still works through deterministic fallbacks.
# - If an operation-specific model is empty, the API uses LLM_MODEL for that operation.
